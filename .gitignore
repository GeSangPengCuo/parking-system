# ===== 后端（Maven/Java）忽略规则 =====
backend/target/       # 忽略后端编译产物
backend/.mvn/         # 忽略maven本地配置
backend/mvnw          # 忽略maven脚本（Windows）
backend/mvnw.cmd      # 忽略maven脚本（Mac/Linux）
*.class               # 忽略Java编译后的.class文件
.idea/                # 忽略IDEA编辑器配置
.vscode/              # 忽略VSCode/Cursor配置
*.iml                 # 忽略IDEA的项目文件

# ===== 前端忽略规则 =====
frontend/.DS_Store    # 忽略Mac系统文件
frontend/*.log        # 忽略前端日志
frontend/node_modules/# （可选）如果用npm会生成，先忽略
frontend/dist/        # （可选）前端打包产物

# ===== 系统通用忽略 =====
*.tmp                 # 临时文件
*.bak                 # 备份文件
.DS_Store             # Mac系统文件